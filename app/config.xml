<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://yourdomain.com/SAGAiptv"
        version="1.0.0"
        viewmodes="fullscreen">

  <!-- ═══ Application identity ═══════════════════════════════════ -->
  <tizen:application id="SAGAiptv.App"
                     package="SAGAiptv"
                     required_version="6.0"
                     launch_mode="single"/>

  <name>SAGA IPTV</name>
  <icon src="icon.png"/>
  <content src="index.html"/>

  <!-- ═══ Content Security Policy ════════════════════════════════
       Allows:
       • inline scripts  (unsafe-inline)  — your JS is inline
       • inline styles   (unsafe-inline)  — your CSS is inline
       • Shaka Player CDN (fallback if local shaka.js fails)
       • All HTTPS media sources (M3U playlists + HLS/DASH streams)
       • blob: and data: for Shaka's media-source segments
  ═══════════════════════════════════════════════════════════════ -->
  <tizen:content-security-policy>
    default-src 'self';
    script-src  'self' 'unsafe-inline'
                https://cdn.jsdelivr.net
                https://cdnjs.cloudflare.com;
    style-src   'self' 'unsafe-inline';
    media-src   *     blob: data:;
    img-src     *     data: blob:;
    connect-src *;
    font-src    'self' data:;
    worker-src  blob:;
    object-src  'none';
  </tizen:content-security-policy>

  <tizen:content-security-policy-report-only>
  </tizen:content-security-policy-report-only>

  <!-- ═══ Features (hardware access declarations) ═════════════════ -->
  <feature name="http://tizen.org/feature/network.internet"/>

  <!-- ═══ Privileges (API access) ════════════════════════════════ -->
  <tizen:privilege name="http://tizen.org/privilege/internet"/>
  <tizen:privilege name="http://tizen.org/privilege/fullscreen"/>
  <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>
  <tizen:privilege name="http://tizen.org/privilege/volume.set"/>
  <tizen:privilege name="http://tizen.org/privilege/mediacapture"/>

  <!-- ═══ Required display engine ════════════════════════════════ -->
  <tizen:profile name="tv"/>

  <!-- ═══ Metadata ════════════════════════════════════════════════
       prelaunch      — app stays in memory after launch (faster zap)
       screen-off     — prevent screen saver during playback
       background     — keep running when user switches away briefly
  ═══════════════════════════════════════════════════════════════ -->
  <tizen:metadata key="http://samsung.com/tv/metadata/prelaunch" value="true"/>
  <tizen:metadata key="http://samsung.com/tv/metadata/screen.off.enable" value="false"/>
  <tizen:metadata key="http://samsung.com/tv/metadata/background.enable" value="true"/>

  <!-- Allow the app to run in the foreground when TV starts -->
  <tizen:setting screen-orientation="landscape"
                 context-menu="disable"
                 background-support="enable"
                 encryption="disable"
                 install-location="auto"
                 hwkey-event="true"/>

  <!-- Register all TV remote colour and media keys your app uses -->
  <tizen:app-control>
    <tizen:src name="index.html"/>
    <tizen:operation name="http://tizen.org/appcontrol/operation/default"/>
  </tizen:app-control>

</widget>
