<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://sagaiptv.app/SAGAiptvWeb"
        version="2.0.0"
        viewmodes="fullscreen">

  <tizen:application id="SAGAiptv.Web"
                     package="SAGAiptvW"
                     required_version="6.0"
                     launch_mode="single"/>

  <n>SAGA IPTV</n>
  <icon src="icon.png"/>
  <content src="index.html"/>
  <description>SAGA IPTV — Shaka Player, Samsung Tizen OS9, M3U/HLS/DASH</description>

  <tizen:content-security-policy>
    default-src 'self';
    script-src  'self' 'unsafe-inline';
    style-src   'self' 'unsafe-inline';
    media-src   * blob: data:;
    img-src     * data: blob:;
    connect-src *;
    font-src    'self' data:;
    worker-src  blob:;
    object-src  'none';
  </tizen:content-security-policy>

  <feature name="http://tizen.org/feature/network.internet"/>
  <feature name="http://tizen.org/feature/tv.display"/>

  <tizen:privilege name="http://tizen.org/privilege/internet"/>
  <tizen:privilege name="http://tizen.org/privilege/fullscreen"/>
  <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>
  <tizen:privilege name="http://tizen.org/privilege/volume.set"/>
  <tizen:privilege name="http://tizen.org/privilege/mediacapture"/>
  <tizen:privilege name="http://tizen.org/privilege/tv.audio"/>

  <tizen:profile name="tv"/>

  <tizen:setting
    screen-orientation="landscape"
    context-menu="disable"
    background-support="enable"
    encryption="disable"
    install-location="auto"
    hwkey-event="true"/>

  <tizen:metadata key="http://samsung.com/tv/metadata/prelaunch"   value="true"/>
  <tizen:metadata key="http://samsung.com/tv/metadata/screen.off.enable" value="false"/>
  <tizen:metadata key="http://samsung.com/tv/metadata/background.enable" value="true"/>

  <tizen:app-control>
    <tizen:src name="index.html"/>
    <tizen:operation name="http://tizen.org/appcontrol/operation/default"/>
  </tizen:app-control>

</widget>
