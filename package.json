{
  "name": "iptv",
  "version": "1.0.1",
  "description": "Premium IPTV player module for TizenBrew — Samsung TV 2K/4K optimised",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pack:check": "npm pack --dry-run",
    "publish:public": "npm publish --access public"
  },
  "files": [
    "app",
    "service.js",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "tizen",
    "tizenbrew",
    "iptv",
    "m3u",
    "hls",
    "samsung",
    "tv"
  ],
  "packageType": "app",
  "appName": "IPTV",
  "appPath": "app/index.html",
  "keys": [
    "MediaPlay",
    "MediaPause",
    "MediaPlayPause",
    "MediaStop",
    "MediaFastForward",
    "MediaRewind",
    "ColorF0Red",
    "ColorF1Green",
    "ColorF2Yellow",
    "ColorF3Blue",
    "ChannelUp",
    "ChannelDown"
  ],
  "serviceFile": "service.js",
  "evaluateScriptOnDocumentStart": false
}
